# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Your Telegram Chat ID (from @userinfobot or @raw_data_bot)
TELEGRAM_CHAT_ID=your-chat-id-here

# Set to true to log raw hook data for debugging
DEBUG=false

# Working directory for Claude CLI (default: ~/.claude/ghost-code/workspace)
# WORKING_DIR=~/projects/my-app

# Claude execution timeout in seconds (default: 300)
# CLAUDE_TIMEOUT=300

# Enable Claude Code statusline integration (default: true)
# Shows model, cost, plan usage, context window, and tool stats in the terminal.
# RTK and websummary stats are auto-detected — shown only if installed.
# Set to false and re-run install.sh to remove the statusline hook.
# STATUSLINE=true
